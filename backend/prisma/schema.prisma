generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model events {
  id               Int               @id @default(autoincrement())
  session_id       Int?
  step_id          Int?
  event_type       String?           @db.VarChar(50)
  timestamp        DateTime?         @default(now()) @db.Timestamp(6)
  reaction_time_ms Int?
  user_lat         Float?
  user_lng         Float?
  metadata         Json?
  sessions         sessions?         @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  navigation_steps navigation_steps? @relation(fields: [step_id], references: [id], onUpdate: NoAction)

  @@index([event_type], map: "idx_events_event_type")
  @@index([session_id], map: "idx_events_session_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model landmarks {
  id               Int                @id @default(autoincrement())
  name             String             @db.VarChar(255)
  lat              Float
  lng              Float
  type             String?            @db.VarChar(50)
  google_place_id  String?            @unique @db.VarChar(255)
  verified         Boolean?           @default(false)
  source           String?            @default("google_places") @db.VarChar(20)
  navigation_steps navigation_steps[]

  @@index([google_place_id], map: "idx_landmarks_google_place_id")
}

model navigation_steps {
  id                Int        @id @default(autoincrement())
  route_id          Int?
  step_index        Int
  instruction_text  String
  distance_m        Int?
  landmark_id       Int?
  is_landmark_based Boolean?   @default(false)
  maneuver          String?    @db.VarChar(50)
  start_lat         Float?
  start_lng         Float?
  end_lat           Float?
  end_lng           Float?
  events            events[]
  landmarks         landmarks? @relation(fields: [landmark_id], references: [id], onUpdate: NoAction)
  routes            routes?    @relation(fields: [route_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([route_id], map: "idx_navigation_steps_route_id")
}

model routes {
  id               Int                @id @default(autoincrement())
  user_id          Int?
  origin_lat       Float
  origin_lng       Float
  dest_lat         Float
  dest_lng         Float
  polyline         String?
  total_distance_m Int?
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  navigation_steps navigation_steps[]
  users            users?             @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sessions         sessions[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model sessions {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  route_id   Int?
  started_at DateTime? @default(now()) @db.Timestamp(6)
  ended_at   DateTime? @db.Timestamp(6)
  mode       String?   @default("hybrid") @db.VarChar(20)
  events     events[]
  routes     routes?   @relation(fields: [route_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([route_id], map: "idx_sessions_route_id")
  @@index([user_id], map: "idx_sessions_user_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  id               Int        @id @default(autoincrement())
  device_id        String     @unique @db.VarChar(255)
  created_at       DateTime?  @default(now()) @db.Timestamp(6)
  updated_at       DateTime?  @updatedAt @db.Timestamp(6)
  preferred_mode   String?    @default("hybrid") @db.VarChar(20)
  consent_research Boolean?   @default(false)
  routes           routes[]
  sessions         sessions[]
}
